+/*
+ * Android does not expose a working /dev/shm or POSIX shm_open(3).
+ * When running under Termux, we emulate shm_open/shm_unlink by storing
+ * shared-memory backing files under $TERMUX_PREFIX/tmp (which maps to
+ * /data/data/com.termux/files/usr/tmp by default).
+ *
+ * @TERMUX_PREFIX@ is substituted at build time by Termux's configure
+ * wrapper.  If it has not been substituted (stand-alone Android build),
+ * we fall back to $TMPDIR and then to /data/local/tmp.
+ */
+
+/* Resolve the runtime base directory exactly once. */
+static const char *get_shm_base_dir(void)
+{
+    /* Prefer the compile-time Termux prefix when it has been substituted. */
+    static const char compiled_prefix[] = "@TERMUX_PREFIX@/tmp";
+
+    /* If @TERMUX_PREFIX@ was never substituted the literal '@' remains. */
+    if (compiled_prefix[0] != '@')
+        return compiled_prefix;
+
+    /* Fall back: honour $TMPDIR at runtime (set by Termux even without
+     * a compiled prefix), then a last-resort Android writable path. */
+    const char *tmpdir = getenv("TMPDIR");
+    if (tmpdir && tmpdir[0] != '\0')
+        return tmpdir;
+
+    return "/data/local/tmp";
+}
+
+/* Ensure the backing directory exists.  Called via pthread_once so it is
+ * both thread-safe and executed at most once per process lifetime. */
+static pthread_once_t shm_dir_once = PTHREAD_ONCE_INIT;
+
+static void ensure_tmp_dir_impl(void)
+{
+    const char *base = get_shm_base_dir();
+    /* Ignore EEXIST; any other error will surface later via open(2). */
+    (void)mkdir(base, 0700);
+}
+
+static void ensure_tmp_dir(void)
+{
+    (void)pthread_once(&shm_dir_once, ensure_tmp_dir_impl);
+}
+
+/* Build the full filesystem path for a POSIX shm name.
+ * Returns 0 on success, -1 with errno set on failure. */
+static int construct_shm_path(const char *name, char *buf, size_t bufsize)
+{
+    /* POSIX requires names to begin with '/'; skip all leading slashes. */
+    while (*name == '/')
+        ++name;
+
+    if (*name == '\0') {
+        errno = EINVAL;
+        return -1;
+    }
+
+    /* Reject names that contain a slash after the leading one(s): POSIX
+     * shm names are flat, not hierarchical. */
+    if (strchr(name, '/') != NULL) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    int n = snprintf(buf, bufsize, "%s/%s", get_shm_base_dir(), name);
+    if (n < 0 || (size_t)n >= bufsize) {
+        errno = ENAMETOOLONG;
+        return -1;
+    }
+
+    return 0;
+}
+
+static int shm_open(const char *name, int oflag, mode_t mode)
+{
+    char fname[PATH_MAX];
+    if (construct_shm_path(name, fname, sizeof(fname)) != 0)
+        return -1;
+
+    ensure_tmp_dir();
+
+    int fd = open(fname, oflag, mode);
+    if (fd == -1)
+        return -1;
+
+    /* Always set FD_CLOEXEC so the fd is not inherited across exec(2). */
+    int fdflags = fcntl(fd, F_GETFD);
+    if (fdflags == -1 || fcntl(fd, F_SETFD, fdflags | FD_CLOEXEC) == -1) {
+        int saved_errno = errno;
+        close(fd);
+        errno = saved_errno;
+        return -1;
+    }
+
+    return fd;
+}
+
+static int shm_unlink(const char *name)
+{
+    char fname[PATH_MAX];
+    if (construct_shm_path(name, fname, sizeof(fname)) != 0)
+        return -1;
+
+    return unlink(fname);
+}
